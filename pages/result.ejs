<!DOCTYPE html>
<html>
    <head>
        <meta name="viewport" content="width=device-width,initial-scsle=1.0">
        <title>
            SEARCH
        </title>
        <link rel="stylesheet" href="/result.css">
    </head>
    <body>
         <nav class="navbar">
            <div class="system">
            <a class="profile" href="/dashboard">Profile</a>
                 <a class="logout" href="/logout">Log Out</a>
            </div>
        </nav>
        <div class="hero"> 
            <table class="form-card">
                <thead class="head">
                    <tr class="hr">
                        <th>Name</th>
                        <th>Enrollment Number</th>                        
                        <th>Registration Number</th>
                        <th>Branch</th>                        
                        <th>Section</th>
                        <th>Phone Number</th>
                        <th>Email</th>
                        <th>Instagram</th>
                    </tr>
                </thead>
                 <tbody class="body">
                  <% users.forEach(user =>{ %>

                        <tr class="br">
                            <td><%= user.name %></td>
                            <!-- <td><%= user.enrollment_number %></td> -->
                            <!-- <td><%= user.registration_number %></td> -->
                            <td><%= user.branch %></td>
                            <td><%= user.section %></td>
                            <!-- <td><%= user.phone_number %></td>
                            <td><%= user.email %></td>
                            <td><%= user.instagram %></td> -->
                        </tr>
                   <% }); %>
                </tbody>
            </table>
        </div>
            
        
    </body>
</html>